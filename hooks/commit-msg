#!/usr/bin/env python3
"""
Git hook: commit-msg
Validate commit message theo format: TASK: ... | BUG: ... | UPDATE: ...
"""

import sys
import re

VALID_PREFIXES = ["TASK:", "BUG:", "UPDATE:"]

SKIP_PATTERNS = [
    r"^Merge ",
    r"^Revert ",
    r"^fixup! ",
    r"^squash! ",
]

# Các cụm từ bị coi là mô tả quá chung chung
VAGUE_PATTERNS = [
    # Tiếng Anh
    r"^(TASK|BUG|UPDATE):\s*(update|updates|updated)\s*$",
    r"^(TASK|BUG|UPDATE):\s*(update|updates|updated)\s+(code|codes|file|files|source|stuff|things)\s*$",
    r"^(TASK|BUG|UPDATE):\s*(fix|fixed|fixes)\b\s*$",
    r"^(TASK|BUG|UPDATE):\s*fix\s+(bug|bugs|issue|issues)\s*$",
    r"^(TASK|BUG|UPDATE):\s*(remove|removed|removes)\s+(some|a\s+few|old|unused)?\s*(code|codes|file|files|stuff|things)\b",
    r"^(TASK|BUG|UPDATE):\s*(add|added|adds)\s+(some|a\s+few)?\s*(code|codes|file|files|stuff|things)\b",
    r"^(TASK|BUG|UPDATE):\s*(minor\s+)?(change|changes|changed)\s*$",
    r"^(TASK|BUG|UPDATE):\s*(clean\s*up|cleanup|cleaning)\s*(code|codes|file|files|stuff|things)?\s*$",
    r"^(TASK|BUG|UPDATE):\s*(refactor|refactoring|refactored)\b\s*$",
    r"^(TASK|BUG|UPDATE):\s*(misc|miscellaneous|wip|work\s+in\s+progress)\b",
    r"^(TASK|BUG|UPDATE):\s*(temp|temporary|tmp)\b",
    r"^(TASK|BUG|UPDATE):\s*(test|testing|tested)\b\s*$",
    r"^(TASK|BUG|UPDATE):\s*(improve|improved|improvement|improvements)\b\s*$",
    r"^(TASK|BUG|UPDATE):\s*(edit|edited|edits)\s*$",
    r"^(TASK|BUG|UPDATE):\s*(edit|edited|edits)\s+(code|codes|file|files|stuff|things)\s*$",
    r"^(TASK|BUG|UPDATE):\s*(modify|modified|modifies)\s*$",
    r"^(TASK|BUG|UPDATE):\s*(modify|modified|modifies)\s+(code|codes|file|files|stuff|things)\s*$",
    r"^(TASK|BUG|UPDATE):\s*(small|minor|tiny)\s+(fix|change|update|edit)\s*$",
    # Tiếng Việt
    r"^(TASK|BUG|UPDATE):\s*(cập\s*nhật|update)\s+(code|file|source|màn\s+hình|screen|giao\s*diện)?\s*$",
    r"^(TASK|BUG|UPDATE):\s*sửa\s+(lỗi|bug)\s*$",
    r"^(TASK|BUG|UPDATE):\s*(xóa|xoá|remove)\s+(một\s+số\s+)?(code|file|hàm|function)\s*$",
    r"^(TASK|BUG|UPDATE):\s*(thêm|add)\s+(một\s+số\s+)?(code|file|thứ|stuff)\s*$",
    r"^(TASK|BUG|UPDATE):\s*(chỉnh\s*sửa|chỉnh|sửa)\s+(nhỏ|nho|lặt\s*vặt|linh\s*tinh)?\s*$",
    r"^(TASK|BUG|UPDATE):\s*(dọn|dọn\s*dẹp|cleanup)\s*(code)?\s*$",
    r"^(TASK|BUG|UPDATE):\s*(tạm\s*thời|tạm|temp)\b",
    r"^(TASK|BUG|UPDATE):\s*(linh\s*tinh|lặt\s*vặt|misc|vv\.?)\b",
]

# Mô tả quá ngắn sau prefix
MIN_DESCRIPTION_WORDS = 3
MIN_DESCRIPTION_CHARS = 7
MAX_FIRST_LINE_CHARS = 100

def is_vague(msg):
    lower = msg.lower().strip()
    for pattern in VAGUE_PATTERNS:
        if re.match(pattern, lower, re.IGNORECASE):
            return True
    return False

def is_too_short(msg):
    # Lấy phần sau "TASK: ", "BUG: " hoặc "UPDATE: "
    for prefix in VALID_PREFIXES:
        if msg.upper().startswith(prefix):
            description = msg[len(prefix):].strip()
            words = [w for w in description.split() if len(w) > 1]
            chars = len(re.sub(r"\s+", "", description))
            return len(words) < MIN_DESCRIPTION_WORDS or chars < MIN_DESCRIPTION_CHARS
    return False

def print_box(lines):
    width = max(len(l) for l in lines) + 2
    print()
    print("╔" + "═" * width + "╗")
    for line in lines:
        padding = width - len(line) - 1
        print("║ " + line + " " * padding + "║")
    print("╚" + "═" * width + "╝")
    print()

def main():
    commit_msg_file = sys.argv[1]
    with open(commit_msg_file, "r", encoding="utf-8") as f:
        msg = f.read().strip()

    lines = [l for l in msg.split("\n") if not l.startswith("#")]
    first_line = lines[0].strip() if lines else ""

    if not first_line:
        print("❌  Commit message không được để trống.")
        sys.exit(1)

    for pattern in SKIP_PATTERNS:
        if re.match(pattern, first_line):
            sys.exit(0)

    # ── Check 1: Đúng prefix chưa ───────────────────────────
    has_valid_prefix = any(first_line.upper().startswith(p) for p in VALID_PREFIXES)
    if not has_valid_prefix:
        print_box([
            "❌  COMMIT BỊ TỪ CHỐI — Sai format",
            "  Prefix hợp lệ: TASK:, BUG:, UPDATE:",
        ])
        print(f"  Message của bạn: \"{first_line}\"")
        print()
        sys.exit(1)

    # ── Check 2: Mô tả quá chung chung ──────────────────────
    if is_vague(first_line):
        print_box([
            "❌  COMMIT BỊ TỪ CHỐI — Mô tả quá chung chung",
        ])
        print(f"  Message của bạn: \"{first_line}\"")
        print()
        sys.exit(1)

    # ── Check 3: Mô tả quá ngắn ─────────────────────────────
    if is_too_short(first_line):
        print_box([
            "❌  COMMIT BỊ TỪ CHỐI — Mô tả quá ngắn",
            "  Cần ít nhất 3 từ và 7 ký tự không tính khoảng trắng sau prefix.",
        ])
        print(f"  Message của bạn: \"{first_line}\"")
        print()
        sys.exit(1)

    # ── Check 4: Dòng đầu quá dài ───────────────────────────
    if len(first_line) > MAX_FIRST_LINE_CHARS:
        print()
        print(f"⚠️  Commit message quá dài (tối đa {MAX_FIRST_LINE_CHARS} ký tự, hiện tại: {len(first_line)}).")
        print(f"   \"{first_line}\"")
        print()
        sys.exit(1)

    sys.exit(0)

if __name__ == "__main__":
    main()
